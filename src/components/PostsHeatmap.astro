---
import { getCollection } from "astro:content";
import dayjs from "dayjs";
import "dayjs/locale/it";
import { createRecentBlogHeatmap } from "@/utils/blog-heatmap";
import { useTranslations } from "@/i18n/utils";
import IconCalendar from "@/assets/icons/IconCalendar.svg";

type Props = {
  lang?: "it" | "en";
  weeks?: number;
};

const { lang = "it", weeks = 20 } = Astro.props;
const t = useTranslations(lang);

const posts = await getCollection(lang === "en" ? "blogEn" : "blog", ({ data }) => !data.draft);
const heatmap = createRecentBlogHeatmap(posts, weeks, 1);
const latest = heatmap.latestPosts[0];

const weekdayLabels =
  lang === "en"
    ? ["Mon", "Tue", "Wed", "Thu", "Fri", "Sat", "Sun"]
    : ["Lun", "Mar", "Mer", "Gio", "Ven", "Sab", "Dom"];
const latestDateLabel = latest
  ? dayjs(latest.date).locale(lang).format("D MMM YYYY")
  : "";

const formatPostCount = (count: number) =>
  `${count} ${t(count === 1 ? "home.activity.post_count_one" : "home.activity.post_count_other")}`;

const formatCellDate = (dateKey: string) =>
  dayjs(dateKey).locale(lang).format("D MMM YYYY");
---

{heatmap.totalPosts > 0 && (
  <div class="activity-card rounded-2xl border border-border/25 bg-muted/10 p-5 backdrop-blur-sm">
    <div class="mb-4 flex items-center gap-2">
      <IconCalendar class="size-4 text-accent" aria-hidden="true" />
      <span class="font-firacode text-[11px] font-bold tracking-widest text-accent/80 uppercase">
        {t("home.activity.title")}
      </span>
    </div>

    <div class="mb-5 grid grid-cols-3 gap-2 text-center">
      <div>
        <p class="text-xl font-bold text-foreground">{heatmap.totalPosts}</p>
        <p class="text-[11px] text-foreground/50">{t("home.activity.total_posts")}</p>
      </div>
      <div>
        <p class="text-xl font-bold text-foreground">{heatmap.activeDays}</p>
        <p class="text-[11px] text-foreground/50">{t("home.activity.active_days")}</p>
      </div>
      <div>
        <p class="text-xl font-bold text-foreground">{heatmap.currentStreak}</p>
        <p class="text-[11px] text-foreground/50">{t("home.activity.streak")}</p>
      </div>
    </div>

    <div class="heatmap-wrap flex gap-2">
      <div class="weekday-col">
        {weekdayLabels.map(label => <span>{label}</span>)}
      </div>
      <div class="heatmap-grid" style={`--weeks: ${heatmap.weeks};`}>
        {heatmap.days.map(day =>
          day.posts.length > 0 ? (
            <a
              href={day.posts[0].href}
              class:list={["heatmap-cell", "heatmap-cell-link", `level-${day.level}`]}
              title={`${formatCellDate(day.date)}: ${day.posts.map(p => p.title).join(", ")}`}
              aria-label={`${formatCellDate(day.date)}: ${day.posts.map(p => p.title).join(", ")}`}
            />
          ) : (
            <span
              class:list={["heatmap-cell", `level-${day.level}`, { "is-future": day.isFuture }]}
              title={day.isFuture ? undefined : `${formatCellDate(day.date)}: ${formatPostCount(day.count)}`}
            />
          )
        )}
      </div>
    </div>

    <div class="mt-3 flex items-center justify-end gap-1 text-[10px] text-foreground/40">
      <span>{t("home.activity.less")}</span>
      {[0, 1, 2, 3, 4].map(level => <span class:list={["legend-cell", `level-${level}`]} />)}
      <span>{t("home.activity.more")}</span>
    </div>

    {latest && (
      <a
        href={latest.href}
        class="group mt-4 flex flex-col gap-0.5 rounded-xl border border-border/20 bg-background/40 px-3 py-2.5 transition-colors duration-200 hover:border-accent/40"
      >
        <span class="flex items-center justify-between gap-2 text-[10px] tracking-wide text-accent/70 uppercase">
          {t("home.activity.latest")}
          <span class="font-firacode text-foreground/35">{latestDateLabel}</span>
        </span>
        <span class="truncate text-sm font-medium text-foreground/85 transition-colors duration-200 group-hover:text-accent">{latest.title}</span>
      </a>
    )}
  </div>
)}

<style>
  .weekday-col {
    display: grid;
    grid-template-rows: repeat(7, 9px);
    gap: 3px;
    font-size: 9px;
    line-height: 9px;
    color: color-mix(in oklab, var(--foreground) 40%, transparent);
  }

  .heatmap-grid {
    display: grid;
    grid-auto-flow: column;
    grid-template-rows: repeat(7, 9px);
    grid-auto-columns: 9px;
    gap: 3px;
    width: calc(var(--weeks) * 12px - 3px);
  }

  .heatmap-cell {
    width: 9px;
    height: 9px;
    border-radius: 2.5px;
    background: color-mix(in oklab, var(--foreground) 6%, transparent);
  }

  @media (max-width: 640px) {
    .heatmap-wrap {
      width: 100%;
    }

    .heatmap-grid {
      flex: 1;
      width: 100%;
      grid-auto-columns: minmax(0, 1fr);
    }

    .heatmap-cell {
      width: auto;
    }
  }

  .heatmap-cell.is-future {
    background: transparent;
  }

  .heatmap-cell-link {
    display: block;
    cursor: pointer;
    transition: transform 0.15s ease, box-shadow 0.15s ease;
  }

  .heatmap-cell-link:hover,
  .heatmap-cell-link:focus-visible {
    transform: scale(1.35);
    box-shadow: 0 0 0 1px color-mix(in oklab, var(--accent) 60%, transparent);
    outline: none;
  }

  .level-1 {
    background: color-mix(in oklab, var(--accent) 25%, transparent);
  }
  .level-2 {
    background: color-mix(in oklab, var(--accent) 45%, transparent);
  }
  .level-3 {
    background: color-mix(in oklab, var(--accent) 70%, transparent);
  }
  .level-4 {
    background: color-mix(in oklab, var(--accent) 95%, transparent);
  }

  .legend-cell {
    display: inline-block;
    width: 8px;
    height: 8px;
    border-radius: 2px;
    background: color-mix(in oklab, var(--foreground) 6%, transparent);
  }
  .legend-cell.level-1 { background: color-mix(in oklab, var(--accent) 25%, transparent); }
  .legend-cell.level-2 { background: color-mix(in oklab, var(--accent) 45%, transparent); }
  .legend-cell.level-3 { background: color-mix(in oklab, var(--accent) 70%, transparent); }
  .legend-cell.level-4 { background: color-mix(in oklab, var(--accent) 95%, transparent); }
</style>
