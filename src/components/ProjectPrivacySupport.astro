---
interface Props {
  title: string;
  lang?: "it" | "en";
  privacyDataTypes?: string;
  privacyStorageNote?: string;
  privacyUpdatedAt?: string;
}

const { title, lang = "it", privacyDataTypes, privacyStorageNote, privacyUpdatedAt } = Astro.props;

const email = "dimpemekug.app@gmail.com";
const isEn = lang === "en";

const labels = {
  privacy: isEn ? "Privacy Policy" : "Privacy",
  updated: isEn ? "Updated" : "Aggiornata",
  support: isEn ? "Support" : "Supporto",
  dataCollected: isEn ? "Data Collected" : "Dati raccolti",
  dataCollectedBody: isEn
    ? `The app processes information you enter directly: ${privacyDataTypes}. We do not collect sensitive data (health, payments, location, contacts, biometrics). No account or registration required.`
    : `L'app elabora le informazioni che inserisci direttamente: ${privacyDataTypes}. Non raccogliamo dati sensibili (salute, pagamenti, posizione, contatti, biometria). Nessun account o registrazione richiesti.`,
  ads: isEn ? "Advertising & Tracking" : "Pubblicità e tracking",
  adsBody: isEn
    ? "No in-app advertising. No tracking or analytics — data is never sent to external servers for profiling."
    : "Nessuna pubblicità in-app. Nessun tracking o analytics — i dati non vengono inviati a server esterni per profilazione.",
  storage: isEn ? "Data Storage" : "Archiviazione",
  storageBody: isEn ? "All information stays on your device." : "Tutte le informazioni rimangono sul dispositivo.",
  sharing: isEn ? "Third-Party Sharing" : "Condivisione con terzi",
  sharingBody: isEn
    ? "We do not sell or share data with third parties."
    : "Non vendiamo né condividiamo dati con terzi.",
  rights: isEn ? "Your Rights" : "Diritti dell'utente",
  rightsBody: isEn
    ? "You can access, modify, and delete your data directly within the app."
    : "Puoi accedere, modificare ed eliminare i tuoi dati direttamente dall'app.",
  contact: isEn ? "Contact" : "Contatti",
  contactBody: isEn
    ? "For questions, bug reports, or feedback:"
    : "Per domande, segnalazioni o feedback:",
  contactReply: isEn ? "We'll get back to you as soon as possible." : "Risponderemo il prima possibile.",
  bug: isEn ? "Reporting a Bug" : "Segnalare un bug",
  bugBody: isEn
    ? "Please include: device model, OS version, and steps to reproduce the issue."
    : "Includi: modello del dispositivo, versione del sistema operativo e passi per riprodurre il problema.",
};
---

<div class="mt-10 space-y-2.5">

  <!-- Privacy -->
  <details class="project-disclosure rounded-2xl border border-border/20 bg-muted/5 backdrop-blur-sm overflow-hidden">
    <summary class="flex cursor-pointer items-center justify-between gap-3 px-5 py-4 select-none [list-style:none] [&::-webkit-details-marker]:hidden transition-colors duration-150 hover:bg-accent/5">
      <div class="flex items-center gap-3">
        <div class="flex size-7 shrink-0 items-center justify-center rounded-lg bg-accent/10 text-accent">
          <svg class="size-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
          </svg>
        </div>
        <div>
          <p class="text-sm font-medium leading-tight text-foreground">{labels.privacy}</p>
          {privacyUpdatedAt && (
            <p class="mt-0.5 font-firacode text-[10px] text-foreground/35">
              {labels.updated}: {privacyUpdatedAt}
            </p>
          )}
        </div>
      </div>
      <svg class="disclosure-chevron size-4 shrink-0 text-foreground/30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <polyline points="6 9 12 15 18 9"/>
      </svg>
    </summary>

    <div class="border-t border-border/10 px-5 pb-5 pt-4">
      <dl class="space-y-4 text-sm text-foreground/65 leading-relaxed">

        {privacyDataTypes && (
          <div>
            <dt class="mb-1 font-firacode text-[10px] font-semibold uppercase tracking-wider text-foreground/40">{labels.dataCollected}</dt>
            <dd>{labels.dataCollectedBody}</dd>
          </div>
        )}

        <div>
          <dt class="mb-1 font-firacode text-[10px] font-semibold uppercase tracking-wider text-foreground/40">{labels.ads}</dt>
          <dd>{labels.adsBody}</dd>
        </div>

        <div>
          <dt class="mb-1 font-firacode text-[10px] font-semibold uppercase tracking-wider text-foreground/40">{labels.storage}</dt>
          <dd>
            {labels.storageBody}
            {privacyStorageNote && <>{" "}{privacyStorageNote}</>}
          </dd>
        </div>

        <div>
          <dt class="mb-1 font-firacode text-[10px] font-semibold uppercase tracking-wider text-foreground/40">{labels.sharing}</dt>
          <dd>{labels.sharingBody}</dd>
        </div>

        <div>
          <dt class="mb-1 font-firacode text-[10px] font-semibold uppercase tracking-wider text-foreground/40">{labels.rights}</dt>
          <dd>{labels.rightsBody}</dd>
        </div>

      </dl>
    </div>
  </details>

  <!-- Support -->
  <details class="project-disclosure rounded-2xl border border-border/20 bg-muted/5 backdrop-blur-sm overflow-hidden">
    <summary class="flex cursor-pointer items-center justify-between gap-3 px-5 py-4 select-none [list-style:none] [&::-webkit-details-marker]:hidden transition-colors duration-150 hover:bg-accent/5">
      <div class="flex items-center gap-3">
        <div class="flex size-7 shrink-0 items-center justify-center rounded-lg bg-accent/10 text-accent">
          <svg class="size-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
          </svg>
        </div>
        <p class="text-sm font-medium text-foreground">{labels.support}</p>
      </div>
      <svg class="disclosure-chevron size-4 shrink-0 text-foreground/30" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <polyline points="6 9 12 15 18 9"/>
      </svg>
    </summary>

    <div class="border-t border-border/10 px-5 pb-5 pt-4">
      <dl class="space-y-4 text-sm text-foreground/65 leading-relaxed">

        <div>
          <dt class="mb-1 font-firacode text-[10px] font-semibold uppercase tracking-wider text-foreground/40">{labels.contact}</dt>
          <dd>
            {labels.contactBody}{" "}
            <a href={`mailto:${email}`} class="text-accent transition-colors hover:underline">{email}</a>
            {" — "}{labels.contactReply}
          </dd>
        </div>

        <div>
          <dt class="mb-1 font-firacode text-[10px] font-semibold uppercase tracking-wider text-foreground/40">{labels.bug}</dt>
          <dd>{labels.bugBody}</dd>
        </div>

      </dl>
    </div>
  </details>

</div>

<script is:inline>
  function initDisclosures() {
    document.querySelectorAll(".project-disclosure").forEach(function (d) {
      if (d.dataset.init) return;
      d.dataset.init = "1";
      var chevron = d.querySelector(".disclosure-chevron");
      if (!chevron) return;
      chevron.style.transition = "transform 0.2s ease";
      d.addEventListener("toggle", function () {
        chevron.style.transform = d.open ? "rotate(180deg)" : "";
      });
    });
  }
  initDisclosures();
  document.addEventListener("astro:after-swap", initDisclosures);
</script>
