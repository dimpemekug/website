---
import "@pagefind/default-ui/css/ui.css";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import { SITE } from "@/config";
---

<Layout title={`Search | ${SITE.title}`}>
  <Header />
  <Breadcrumb />
  <main id="main-content" class="app-layout pb-12">
    <div class="page-hero" data-page-hero>
      <div class="aurora-orb aurora-orb-1"></div>
      <div class="aurora-orb aurora-orb-2"></div>
      <div class="aurora-orb aurora-orb-3"></div>
      <div class="aurora-mouse" data-hero-mouse></div>
      <div class="relative z-10">
        <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">
          <span class="glow-text">Search</span>
        </h1>
        <p class="mt-3 max-w-lg text-foreground/70 italic">
          Find any article, tutorial, or idea on the blog.
        </p>
      </div>
    </div>
    <div id="search" class="premium-search mt-4"></div>
  </main>
  <Footer />
</Layout>

<script>
  import { PagefindUI } from "@pagefind/default-ui";
  window.addEventListener("DOMContentLoaded", () => {
    new PagefindUI({
      element: "#search",
      showSubResults: true,
      showImages: false,
    });
    const input = document.querySelector<HTMLInputElement>(".pagefind-ui__search-input");
    if (input) {
      input.placeholder = "Search posts...";
      input.focus();
    }
  });
</script>
