---
import { getCollection } from "astro:content";
import type { GetStaticPathsOptions } from "astro";
import Layout from "@/layouts/Layout.astro";
import Header from "@/components/Header.astro";
import Footer from "@/components/Footer.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import Card from "@/components/Card.astro";
import Pagination from "@/components/Pagination.astro";
import getUniqueTags from "@/utils/getUniqueTags";
import getPostsByTag from "@/utils/getPostsByTag";
import { SITE } from "@/config";

export async function getStaticPaths({ paginate }: GetStaticPathsOptions) {
  const [blogPosts, galleryPosts] = await Promise.all([
    getCollection("blog"),
    SITE.showGalleries && SITE.showGalleriesInIndex
      ? getCollection("galleries")
      : Promise.resolve([]),
  ]);
  const posts = [...blogPosts, ...galleryPosts];
  const tags = getUniqueTags(posts);

  return tags.flatMap(({ tag, tagName }) => {
    const tagPosts = getPostsByTag(posts, tag);
    return paginate(tagPosts, {
      params: { tag },
      props: { tagName },
      pageSize: SITE.postPerPage,
    });
  });
}

const params = Astro.params;
const { tag } = params;
const { page, tagName } = Astro.props;

const tagOgImage = `/tags/${tag}/og.png`;

const metaTitle = page.currentPage > 1
  ? `Tag: ${tagName} (Pagina ${page.currentPage} di ${page.lastPage}) | ${SITE.title}`
  : `Tag: ${tagName} | ${SITE.title}`;

const tagDescription = page.currentPage > 1
  ? `Tutti gli articoli con il tag "${tagName}" su ${SITE.title} (Pagina ${page.currentPage} di ${page.lastPage}).`
  : `Tutti gli articoli con il tag "${tagName}" su ${SITE.title}.`;

const prevURL = page.url.prev ? new URL(page.url.prev, SITE.website).toString() : undefined;
const nextURL = page.url.next ? new URL(page.url.next, SITE.website).toString() : undefined;
---

<Layout title={metaTitle} description={tagDescription} ogImage={tagOgImage} prev={prevURL} next={nextURL}>
  <Header />
  <Breadcrumb />
  <main id="main-content" class="app-layout pb-12">

    <!-- Hero -->
    <div class="page-hero" data-page-hero>
      <div class="aurora-orb aurora-orb-1"></div>
      <div class="aurora-orb aurora-orb-2"></div>
      <div class="aurora-orb aurora-orb-3"></div>
      <div class="aurora-mouse" data-hero-mouse></div>
      <div class="relative z-10">
        <p class="tag-eyebrow">Tag</p>
        <h1 class="text-3xl font-bold tracking-tight sm:text-4xl">
          <span class="glow-text" transition:name={tag}>#{tagName}</span>
        </h1>
        <p class="mt-3 max-w-lg text-foreground/70 italic">
          Tutti gli articoli con il tag "{tagName}".
        </p>
        <div class="mt-4 flex flex-wrap items-center gap-2">
          <span class="hero-badge">{page.total} post</span>
          {page.lastPage > 1 && (
            <span class="hero-badge">Pagina {page.currentPage}/{page.lastPage}</span>
          )}
        </div>
      </div>
    </div>

    <!-- Posts -->
    {page.data.length === 0 ? (
      <p class="py-12 text-center opacity-50">Nessun articolo trovato.</p>
    ) : (
      <ul>
        {page.data.map((data, index) => (
          <Card
            {...data}
            loading={index < 3 ? "eager" : "lazy"}
            fetchpriority={index < 3 ? "high" : "auto"}
          />
        ))}
      </ul>
    )}

    <Pagination {page} />
  </main>
  <Footer noMarginTop={page.lastPage > 1} />
</Layout>

<style>
  .tag-eyebrow {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-accent);
    opacity: 0.7;
    margin-bottom: 0.25rem;
  }
</style>
